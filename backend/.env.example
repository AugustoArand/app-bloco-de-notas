# ─────────────────────────────────────────────────────
# Cloudflare R2 — Active Storage
#
# Onde encontrar cada valor no dashboard da Cloudflare:
#   Account ID          → sidebar direito em qualquer página do R2
#   Bucket              → R2 > nome do bucket criado por você
#   Access Key ID       → R2 > Manage R2 API Tokens > Create API Token
#   Secret Access Key   → exibido apenas uma vez ao criar o token
# ─────────────────────────────────────────────────────

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# URL pública do frontend (usada no CORS)
# Exemplo: https://app-bloco-de-notas.vercel.app
FRONTEND_URL=
