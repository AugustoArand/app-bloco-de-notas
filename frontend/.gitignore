# =============================================
# NoteVault Frontend — Vite / Vue 3 .gitignore
# =============================================

# ── Dependências ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build ─────────────────────────────────────
dist/
dist-ssr/
build/

# ── Variáveis de ambiente ─────────────────────
.env
.env.*
!.env.example
*.local

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Cache Vite ────────────────────────────────
.vite/
.vite-cache/

# ── Cache Vue / TypeScript ────────────────────
*.tsbuildinfo

# ── Testes ────────────────────────────────────
coverage/
.vitest/

# ── Editor ────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Sistema Operacional ───────────────────────
.DS_Store
Thumbs.db
